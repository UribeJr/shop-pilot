{
  "name": "notion-store-analyst",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @notion-store-analyst/web",
    "build": "npm run build --workspace @notion-store-analyst/web",
    "build:render": "cp prisma/schema.postgresql.prisma prisma/schema.prisma && npx prisma generate && npx prisma db push && npm run build --workspace @notion-store-analyst/web",
    "lint": "npm run lint --workspace @notion-store-analyst/web",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "demo:sync": "tsx scripts/run-demo-sync.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.5.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "prisma": "^6.5.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
